{
  "name": "sensa-chrome-extension",
  "displayName": "Sensa - Accessibility & Sensory Assistant",
  "version": "1.0.0",
  "description": "An advanced dual-mode accessibility extension offering live AI subtitles, translation, text-to-speech reading enhancements, and sensory customization.",
  "author": "Sensa",
  "scripts": {
    "dev": "npx plasmo dev",
    "build": "npx plasmo build && node scripts/fix-manifest.js",
    "build:prod": "npx plasmo build --target=chrome-mv3 --prod && node scripts/fix-manifest.js",
    "package": "npx plasmo package && node scripts/fix-manifest.js",
    "postbuild": "node scripts/fix-manifest.js"
  },
  "dependencies": {
    "annyang": "^3.0.0",
    "motion": "^12.38.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-transition-group": "^4.4.5",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/annyang": "^2.6.5",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "version": "1.0.0",
    "description": "An advanced dual-mode accessibility extension offering live AI subtitles, translation, text-to-speech reading enhancements, and sensory customization.",
    "permissions": [
      "scripting",
      "storage",
      "tabCapture",
      "offscreen"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}